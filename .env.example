# SSH Configuration Defaults
# Copy this file to .env and fill in your details

# Remote host address (e.g., localhost, 192.168.1.10)
SSH_HOST=

# SSH username
SSH_USERNAME=

# SSH password (optional if using key_filename)
SSH_PASSWORD=

# Path to SSH private key file (optional)
SSH_KEY_FILENAME=

# SSH port (default: 22)
SSH_PORT=22
